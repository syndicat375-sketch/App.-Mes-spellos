// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: shifts
// Document ID: auto-generated
// Fields:
//   - date: string (ISO 8601) - required
//   - configType: string (enum: ['2-employees', '3-employees']) - required
//   - assignments: array of objects { employeeName: string, relayType: string } - required
//   - employeeNames: array of strings - required
//   - createdBy: string (uid) - required
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dabardeurs@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidShift(data) {
      return data.keys().hasAll(['date', 'configType', 'assignments', 'employeeNames', 'createdBy']) &&
             data.date is string &&
             data.configType in ['2-employees', '3-employees'] &&
             data.assignments is list &&
             data.employeeNames is list &&
             data.createdBy is string &&
             data.createdBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /shifts/{shiftId} {
      allow read: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidShift(request.resource.data);
      allow update: if isAuthenticated() && isValidShift(request.resource.data) && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
